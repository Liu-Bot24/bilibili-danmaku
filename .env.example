# Copy this file to .env or export these variables in your process manager.
# Keep real values out of Git.

# Runtime paths
BILI_DANMAKU_PROJECT_ROOT=/path/to/bilibili_danmaku
BILI_DANMAKU_LOG_FILE=/path/to/bilibili_danmaku/app.log
BILI_DANMAKU_STATE_DB=/path/to/bilibili_danmaku/.state/bilibili_danmaku.sqlite3
BILI_DANMAKU_SECRET_FILE=/path/to/private/bilibili_danmaku.secrets.json
BILI_DANMAKU_MODEL_CONFIG_FILE=/path/to/private/bilibili_danmaku.model_config.json
BILI_DANMAKU_WORKER_LOG_FILE=/path/to/logs/worker.log

# Maintenance API token
BILI_DANMAKU_APP_TOKEN=

# Search engine submission token
BILI_DANMAKU_BAIDU_SUBMIT_TOKEN=

# Built-in OpenAI-compatible model examples
BILI_DANMAKU_PRIMARY_ENDPOINT=https://api.example.com/v1/chat/completions
BILI_DANMAKU_PRIMARY_API_KEY=
BILI_DANMAKU_SECONDARY_ENDPOINT=https://api2.example.com/v1/chat/completions
BILI_DANMAKU_SECONDARY_API_KEY=
